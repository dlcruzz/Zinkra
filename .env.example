# Para desenvolvimento local com Vercel Dev (vercel dev):
# A variável abaixo NÃO precisa do prefixo VITE_ — ela roda apenas no servidor
PROPOSALS_PASSWORD=sua-senha-aqui

# Para desenvolvimento local SEM Vercel Dev (npm run dev):
# Crie um .env.local com a variável abaixo como fallback client-side:
VITE_PROPOSALS_PASSWORD=sua-senha-aqui
